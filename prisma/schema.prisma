generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// -------------------------------------
// USER & AUTHENTICATION
// -------------------------------------
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?   
  firstName     String?
  lastName      String?
  role          Role      @default(CUSTOMER)
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  CUSTOMER
  ADMIN
}

// -------------------------------------
// PRODUCT & INVENTORY
// -------------------------------------
model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String      @db.Text
  price       Decimal     @db.Decimal(10, 2)
  isAvailable Boolean     @default(true)
  
  // Images
  imageFront  String
  imageBack   String
  
  // Relationships
  inventory   Inventory[]
  orderItems  OrderItem[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Tracks individual stock per size (S, M, L, XL, XXL)
model Inventory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      String   
  stock     Int      @default(0)

  @@unique([productId, size]) 
}

// -------------------------------------
// ORDERS & TRANSACTIONS
// -------------------------------------
model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique // e.g., MV-10024
  userId          String?       
  user            User?         @relation(fields: [userId], references: [id])
  
  // Customer Details Snapshot
  customerEmail   String
  customerName    String
  customerPhone   String?
  
  // Nigerian Shipping Address
  shippingAddress String
  state           String
  lga             String
  
  // Financials (Stored in NGN)
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingFee     Decimal       @db.Decimal(10, 2)
  tax             Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  
  // Statuses
  paymentStatus   PaymentStatus @default(PENDING)
  orderStatus     OrderStatus   @default(PROCESSING)
  paymentMethod   String        @default("paystack")
  transactionId   String?       // Paystack Reference
  
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String  
  price     Decimal @db.Decimal(10, 2) 
  size      String
  quantity  Int
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
}