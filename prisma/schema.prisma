generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  stock       Int      @default(0)
  imageFront  String   
  gallery     String?
  imageBack   String   
  category    String   @default("tees")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id             String      @id @default(cuid())
  reference      String      @unique
  email          String
  name           String?     // Added
  phone          String?     // Added
  amount         Float
  shippingMethod String
  shippingDetails Json
  status         String      @default("Pending")
  createdAt      DateTime    @default(now())
  
  // Relation to the items
  items          OrderItem[] 
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  name      String
  size     String?
  quantity  Int
  price     Float
}