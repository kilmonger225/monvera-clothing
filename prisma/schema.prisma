generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  stock       Int      @default(0)
  imageFront  String   
  imageBack   String   
  createdAt   DateTime @default(now())
}
model Order {
  id             String   @id @default(cuid())
  reference      String   @unique
  email          String
  amount         Float
  shippingMethod String
  status         String   @default("Pending")
  createdAt      DateTime @default(now())
}